# API rotaları: /api/blog → index.php?path=blog
# /api/blog/lgs-yazisi → index.php?path=blog/lgs-yazisi
RewriteEngine On

# .htaccess'in bulunduğu klasörden başlatılır
RewriteBase /api/

# Eğer istenen dosya gerçekten varsa (örn. install.php), aynen servis et
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Aksi takdirde index.php'ye yönlendir
RewriteRule ^(.*)$ index.php?path=$1 [QSA,L]

# ------------------------------------------------------------
# CORS: sadece bilinen origin'lere izin (whitelist)
#   - localhost (her port)
#   - ferizliilkadimakademi.com  (http/https)
# ------------------------------------------------------------
SetEnvIf Origin "^https?://(localhost(:[0-9]+)?|ferizliilkadimakademi\.com)$" CORS_ALLOWED=$0
Header set Access-Control-Allow-Origin "%{CORS_ALLOWED}e" env=CORS_ALLOWED
Header always set Access-Control-Allow-Credentials "true"
Header always set Vary "Origin"

# Güvenlik başlıkları
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"

# config.php doğrudan istenirse engelle
<Files "config.php">
  Require all denied
</Files>
