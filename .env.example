# ============================================================
# Ferizli İlk Adım Akademi — Ortam Değişkenleri (örnek)
# ============================================================
# Kullanım:
#   cp .env.example .env
#   # değerleri kendi ortamına göre güncelle (özellikle şifreleri!)
#   docker compose up -d
#
# .env DOSYASI GİT'E EKLENMEZ (.gitignore'da listelidir).
# ============================================================

# MariaDB root parolası — phpMyAdmin'in root erişimi için de kullanılır
DB_ROOT_PASSWORD=changeme-strong-password

# Uygulama veritabanı adı
DB_NAME=ilkadim_db

# Uygulamanın bağlanacağı kullanıcı (root değil!)
DB_USER=ilkadim_user
DB_PASSWORD=changeme-user-password

# PHP ortamı: dev | prod
# - dev   → display_errors=On, daha gevşek
# - prod  → hatalar log'a yazılır, dışarı sızmaz
PHP_ENV=dev
